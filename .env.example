# Copy from hatikvah-care-fntd/.env or fill in your Supabase credentials
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Customer storefront URL ("View Storefront" + "View on website" in admin)
VITE_STORE_URL="https://hatikvahcare.com"
NEXT_PUBLIC_MINIO_BUCKET_NAME="hatikvahstorage"

# Supabase S3 storage (required for product images + catalogue PDFs)
# Bucket must be public so https://hatikvahcare.com can load image URLs.
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3"
S3_REGION="ap-south-1"
S3_BUCKET_NAME="products"

# Admin sign-in (server only — never commit real values; keep them in .env / host env vars)
STORE_LOGIN_EMAIL="your-admin-email@example.com"
STORE_LOGIN_PASSWORD="change-me"

# Optional: long random secret used to seal the httpOnly admin session cookie
# ADMIN_SESSION_SECRET="replace-with-a-long-random-string"
